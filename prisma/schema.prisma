// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

model Url {
  id           Int       @id @default(autoincrement())
  originalUrl  String
  shortCode    String    @unique
  clicks       Int       @default(0)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
  userId       Int?
  user         User?     @relation(fields: [userId], references: [id])
  clickHistory Click[]

  @@index([expiresAt])
  @@index([userId])
}

model Click {
  id        Int      @id @default(autoincrement())
  urlId     Int
  url       Url      @relation(fields: [urlId], references: [id], onDelete: Cascade)
  clickedAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([urlId])
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  urls          Url[]
}

// One-time codes for email verification and password reset. The code itself is
// stored HASHED (never plaintext) — it's a credential. Short-lived + attempt-
// limited to resist brute force of the 6-digit space.
model OtpToken {
  id         Int      @id @default(autoincrement())
  email      String
  codeHash   String
  type       OtpType
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([email, type])
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}
