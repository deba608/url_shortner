// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String?
  avatar            String?
  password          String
  // Set whenever the password changes. Session + reset tokens issued before this
  // instant are rejected — gives single-use resets and logout-everywhere on reset.
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  urls              Url[]
}

model Url {
  id           Int       @id @default(autoincrement())
  originalUrl  String
  shortCode    String    @unique
  clicks       Int       @default(0)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  clickHistory Click[]

  @@index([expiresAt])
  @@index([userId])
}

model Click {
  id        Int      @id @default(autoincrement())
  urlId     Int
  url       Url      @relation(fields: [urlId], references: [id], onDelete: Cascade)
  clickedAt DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([urlId])
  // Composite index backs the per-url daily/weekly click counts (filter by urlId,
  // range on clickedAt) and the latest-click / history ordering.
  @@index([urlId, clickedAt])
}
