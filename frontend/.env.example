# ── Local Development ─────────────────────────────────────────────
# In dev, Vite proxies /auth, /shorten, etc. to localhost:3000,
# so leave VITE_API_URL empty (same-origin proxy, no CORS needed).
# VITE_API_URL=

# ── Vercel / Production ────────────────────────────────────────────
# Set this to your Render API URL when deploying the frontend to Vercel.
# Example: https://url-shortener-api.onrender.com
# Do NOT include a trailing slash.
VITE_API_URL=https://your-render-api.onrender.com
