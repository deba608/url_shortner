# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/url_shortener"

# ── Authentication (Clerk) ────────────────────────────────────────
# Auth is handled by Clerk. Get these keys from the Clerk dashboard
# (https://dashboard.clerk.com → API Keys). The backend needs the secret key;
# the frontend needs the publishable key (set in frontend/.env.local as
# VITE_CLERK_PUBLISHABLE_KEY).
CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxx"

# Redis (defaults to redis://localhost:6379 in development)
REDIS_URL="redis://localhost:6379"

# Server
PORT=3000
BASE_URL="http://localhost:3000"
NODE_ENV="development"

# Optional: Winston log level override (info | debug | warn | error)
# LOG_LEVEL="debug"

# ── Email (Gmail SMTP) ─────────────────────────────────────────────
# Required for password-reset emails. Use a Gmail address and an App
# Password (NOT your regular Gmail password). Generate one at:
# https://myaccount.google.com/apppasswords
EMAIL_USER="your-email@gmail.com"
EMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Frontend URL used in password-reset links
FRONTEND_URL="http://localhost:5173"